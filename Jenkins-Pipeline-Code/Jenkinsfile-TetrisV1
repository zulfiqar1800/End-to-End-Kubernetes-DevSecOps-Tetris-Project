pipeline {
    agent any

    tools {
        nodejs 'nodejs'
    }

    environment {
        SCANNER_HOME = tool 'sonar-scanner'
    }

    stages {

        stage('Cleaning Workspace') {
            steps { cleanWs() }
        }

        stage('Checkout from Git') {
            steps {
                git branch: 'master', url: 'https://github.com/rasheed1800/End-to-End-Kubernetes-DevSecOps-Tetris-Project.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('Tetris-V1') {
                    withSonarQubeEnv('sonar-scanner') {
                        sh '''
                            $SCANNER_HOME/bin/sonar-scanner \
                            -Dsonar.projectName=TetrisV1 \
                            -Dsonar.projectKey=TetrisV1
                        '''
                    }
                }
            }
        }

        stage('Quality Check') {
            steps {
                waitForQualityGate abortPipeline: false, credentialsId: 'sonar-token'
            }
        }

        stage('Installing Dependencies') {
            steps {
                dir('Tetris-V1') { sh 'npm install' }
            }
        }

        stage('OWASP Dependency-Check Scan') {
            steps {
                dir('Tetris-V1') {
                    dependencyCheck additionalArguments: '--scan ./ --disableYarnAudit --disableNodeAudit', odcInstallation: 'DP-Check'
                    dependencyCheckPublisher pattern: '**/dependency-check-report.xml'
                }
            }
        }

        stage('Trivy File Scan') {
            steps {
                dir('Tetris-V1') { sh 'trivy fs . > trivyfs.txt' }
            }
        }

        stage('Docker Image Build') {
            steps {
                dir('Tetris-V1') {
                    withDockerRegistry(credentialsId: 'docker', toolName: 'docker') {
                        sh 'docker system prune -f'
                        sh 'docker build -t tetrisv1 .'
                    }
                }
            }
        }

        stage('Docker Image Push') {
            steps {
                withDockerRegistry(credentialsId: 'docker', toolName: 'docker') {
                    sh 'docker tag tetrisv1 rasheed1800/tetrisv1:${BUILD_NUMBER}'
                    sh 'docker push rasheed1800/tetrisv1:${BUILD_NUMBER}'
                }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh 'trivy image rasheed1800/tetrisv1:${BUILD_NUMBER} > trivyimage.txt'
            }
        }

        stage('Update Deployment File') {
            environment {
                GIT_REPO_NAME = "End-to-End-Kubernetes-DevSecOps-Tetris-Project"
                GIT_USER_NAME = "rasheed1800"
            }
            steps {
                dir('Manifest-file') {
                    withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
                        sh '''
                            git config user.email "rasheed1800@gmail.com"
                            git config user.name "rasheed1800"

                            imageTag=$(grep -oP '(?<=tetrisv1:)[^ ]+' deployment.yaml)
                            sed -i "s/tetrisv1:${imageTag}/tetrisv1:${BUILD_NUMBER}/" deployment.yaml

                            git add deployment.yaml
                            git commit -m "Update deployment image to version ${BUILD_NUMBER}"
                            git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:master
                        '''
                    }
                }
            }
        }
    }
}
